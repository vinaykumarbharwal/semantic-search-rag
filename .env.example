# LLM API Keys
OPENAI_API_KEY=your_openai_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# System Configurations
LOG_LEVEL=INFO
APP_ENV=development

# Path Configurations
DATA_DIR=./data
MODELS_DIR=./models
INDEX_PATH=./models/faiss_index

# RAG Configurations
CHUNK_SIZE=512
CHUNK_OVERLAP=64
EMBEDDING_MODEL=all-MiniLM-L6-v2
RETRIEVAL_K=5
